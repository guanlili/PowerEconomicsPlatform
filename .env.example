# 电力看经济平台 - 端口与连接配置示例
# 使用方法：复制本文件为 .env，根据目标服务器情况调整端口
#   cp .env.example .env
# docker compose 会自动读取 .env 中的变量
#
# 默认部署策略：仅前端对外暴露端口，后端与 MySQL 只在 docker 内部网络互通
#   FRONTEND_PORT  唯一对外提供服务的端口，浏览器访问入口
#   BACKEND_PORT   仅在 docker-compose.yml 里打开 backend.ports 注释后生效（用于 Swagger / 外部联调）
#   MYSQL_PORT     仅在 docker-compose.yml 里打开 mysql.ports 注释后生效（用于本地 GUI 工具连库）

FRONTEND_PORT=8094

# 默认不生效，需要时同步取消 docker-compose.yml 对应 ports 注释
BACKEND_PORT=8000
MYSQL_PORT=3306
